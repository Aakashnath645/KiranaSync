# Auto-detect text files and normalize line endings
* text=auto

# Specify text files that must use LF line endings
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Protect binary files from line ending translation
*.jar binary
*.png binary
*.webp binary
*.keystore binary
*.bin binary
